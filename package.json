{
  "name": "versator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "appts": "redrun lint format typecheck build",
    "clean": "rimraf --glob **/node_modules **/dist **/.next **/.tsbuildinfo **/.react-email",
    "build": "next build",
    "dev": "next dev --turbo",
    "start": "next start",
    "lint": "eslint --cache --fix .",
    "typecheck": "tsc --noEmit",
    "format": "redrun biome:write",
    "biome:write": "biome format --write .",
    "biome:check": "biome lint --write .",
    "check": "bun lint && bun typecheck && bun format:check",
    "shadcn:add": "bunx shadcn-ui@latest add",
    "db:generate": "dotenv drizzle-kit generate",
    "db:introspect": "dotenv drizzle-kit introspect",
    "db:push": "dotenv drizzle-kit push",
    "db:migrate": "dotenv tsx src/db/migrate.ts",
    "db:drop-migration": "drizzle-kit drop",
    "db:seed": "dotenv tsx src/db/seed.ts",
    "db:studio": "dotenv drizzle-kit studio",
    "email:dev": "email dev --dir src/components/emails -p 3001",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe --latest",
    "unlighthouse": "bunx unlighthouse --site https://versator.vercel.app"
  },
  "dependencies": {
